# ==============================================================================
# SupplyFlow Environment Configuration
# ==============================================================================
# Copy this file to .env and update the values for your environment.

# ------------------------------------------------------------------------------
# Django
# ------------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=your-secret-key-change-in-production-at-least-50-chars
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_DB=supplyflow
POSTGRES_USER=supplyflow
POSTGRES_PASSWORD=supplyflow
DATABASE_URL=postgres://supplyflow:supplyflow@db:5432/supplyflow

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# Celery
# ------------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ------------------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost/api

# ------------------------------------------------------------------------------
# Email (SMTP) - Production
# ------------------------------------------------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=SupplyFlow <noreply@example.com>

# ------------------------------------------------------------------------------
# Sentry (optional - production error tracking)
# ------------------------------------------------------------------------------
SENTRY_DSN=

# ------------------------------------------------------------------------------
# AWS S3 (optional - production file storage)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
